# ArchiTrack environment configuration
# Copy to .env (local dev) and fill in real values. See spec/02-architecture.md §3.

# Postgres connection string used by Prisma and the app.
DATABASE_URL="postgresql://architrack:architrack@localhost:5432/architrack?schema=public"

# Auth.js (NextAuth v5) secret — generate with `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET="change-me-to-a-random-32-byte-secret"

# Public base URL of the app (used in emails, invite links, absolute redirects).
APP_URL="http://localhost:3000"

# SMTP (Nodemailer) — invites, notifications, password reset.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="ArchiTrack <noreply@example.com>"

# Local filesystem storage for uploads (mounted as a Docker volume in production).
UPLOADS_DIR="/data/uploads"
MAX_UPLOAD_MB="500"

# Default UI locale (sk | en).
DEFAULT_LOCALE="sk"

# --- Seed script only (not read at runtime) ---
SEED_ADMIN_EMAIL="admin@architrack.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# --- docker-compose.dev.yml Postgres credentials (must match DATABASE_URL above) ---
POSTGRES_USER="architrack"
POSTGRES_PASSWORD="architrack"
POSTGRES_DB="architrack"
